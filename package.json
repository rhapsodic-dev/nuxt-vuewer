{
  "name": "@rhapsodic/nuxt-vuewer",
  "version": "1.4.2",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "rhapsodic.dev",
    "email": "rhapsodic.dev@gmail.com",
    "url": "https://github.com/rhapsodic-dev"
  },
  "contributors": [
    {
      "name": "Svyatoslav Fyodorov",
      "email": "intelrug@gmail.com",
      "url": "https://github.com/intelrug"
    },
    {
      "name": "TrenLok",
      "email": "trenlok.dev@gmail.com",
      "url": "https://github.com/trenlok"
    }
  ],
  "description": "Nuxt module for viewing images",
  "homepage": "https://github.com/rhapsodic-dev/nuxt-vuewer.git#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhapsodic-dev/nuxt-vuewer.git"
  },
  "bugs": {
    "url": "https://github.com/rhapsodic-dev/nuxt-vuewer/issues"
  },
  "keywords": [
    "image",
    "nuxt",
    "viewer"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs",
      "default": "./dist/module.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "start": "npm run dev",
    "build": "npm run dev:build",
    "dev": "npm run dev:prepare && nuxi dev playground --host 0.0.0.0 --public",
    "dev:build": "nuxi build playground",
    "dev:generate": "nuxi generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "dev:preview": "nuxi preview playground",
    "typecheck": "nuxi typecheck playground",
    "release": "bumpp",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepare": "pnpm run hooks:install",
    "hooks:install": "pnpm exec simple-git-hooks"
  },
  "dependencies": {
    "@rhapsodic/vuewer": "^1.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "^24.12.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "sass": "^1.98.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm exec commitlint --edit",
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
